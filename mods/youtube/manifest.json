{
  "mod_id": "youtube",
  "name": "YouTube",
  "version": "0.1.6",
  "author": "Project Lyra",
  "category": "Media",
  "description": "Adds a YouTube tile to the Start menu: a marketplace-style landing (search + browse) and a search-results list whose rows stream YouTube Music through the native queue via the ytm:// source.",
  "changelog": "Tapping a song in a list now plays it and queues the whole list, so next and previous move through the other tracks. Each track carries its own title, artist, and art.",
  "experimental": true,
  "depends_on": [],
  "daemons": [
    { "binary": "@/ytsearchd.exe" }
  ],
  "actions": [
    {
      "type": "lyra.gem_add_entry",
      "gem": "scenes_standard.gem",
      "entry_name": "YouTube.xur",
      "content_blob_ref": "@/scenes/YouTube.xur"
    },
    {
      "type": "lyra.gem_add_entry",
      "gem": "scenes_standard.gem",
      "entry_name": "YtSearch.xur",
      "content_blob_ref": "@/scenes/YtSearch.xur"
    },
    {
      "type": "lyra.gem_add_entry",
      "gem": "scenes_standard.gem",
      "entry_name": "YtSearchSongs.xur",
      "content_blob_ref": "@/scenes/YtSearchSongs.xur"
    },
    {
      "type": "lyra.gem_add_entry",
      "gem": "scenes_standard.gem",
      "entry_name": "YtSearchAlbums.xur",
      "content_blob_ref": "@/scenes/YtSearchAlbums.xur"
    },
    {
      "type": "lyra.gem_add_entry",
      "gem": "scenes_standard.gem",
      "entry_name": "YtSearchArtists.xur",
      "content_blob_ref": "@/scenes/YtSearchArtists.xur"
    },
    {
      "type": "lyra.gem_add_entry",
      "gem": "scenes_standard.gem",
      "entry_name": "YtAlbum.xur",
      "content_blob_ref": "@/scenes/YtAlbum.xur"
    },
    {
      "type": "lyra.gem_add_entry",
      "gem": "scenes_standard.gem",
      "entry_name": "YtArtist.xur",
      "content_blob_ref": "@/scenes/YtArtist.xur"
    },
    {
      "type": "lyra.gem_add_entry",
      "gem": "scenes_standard.gem",
      "entry_name": "YtArtistAlbums.xur",
      "content_blob_ref": "@/scenes/YtArtistAlbums.xur"
    },
    {
      "type": "lyra.gem_add_entry",
      "gem": "scenes_standard.gem",
      "entry_name": "YtArtistSongs.xur",
      "content_blob_ref": "@/scenes/YtArtistSongs.xur"
    },
    {
      "type": "lyra.xus_add_string",
      "gem": "strings.gem",
      "table": "Strings.xus",
      "locale": "en",
      "value": "youtube",
      "manifest_back_reference": "youtube_label"
    },

    { "type": "lyra.registry_write", "hive": "HKCR", "key": "ytm", "name": "Source Filter", "value_type": "SZ", "value": "{C0FFEE06-2026-4A6E-B0DE-5965594A5959}" },
    { "type": "lyra.registry_write", "hive": "HKCR", "key": "ytm", "name": "URL Protocol", "value_type": "SZ", "value": "" },
    { "type": "lyra.registry_write", "hive": "HKCR", "key": "CLSID\\{C0FFEE06-2026-4A6E-B0DE-5965594A5959}", "value_type": "SZ", "value": "Xune YouTube Stream Source" },
    { "type": "lyra.registry_write", "hive": "HKCR", "key": "CLSID\\{C0FFEE06-2026-4A6E-B0DE-5965594A5959}", "name": "Merit", "value_type": "DWORD", "value": "0x800002" },
    { "type": "lyra.registry_write", "hive": "HKCR", "key": "CLSID\\{C0FFEE06-2026-4A6E-B0DE-5965594A5959}\\InprocServer32", "value_type": "SZ", "value": "@/ce_ytmstream.dll" },
    { "type": "lyra.registry_write", "hive": "HKCR", "key": "CLSID\\{C0FFEE06-2026-4A6E-B0DE-5965594A5959}\\InprocServer32", "name": "ThreadingModel", "value_type": "SZ", "value": "Both" },

    {
      "type": "lyra.load_module",
      "target_proc": "gemstone",
      "module_ref": "@/youtube.dll",
      "init": "YtInstall"
    },
    {
      "type": "lyra.inject_menu_entry",
      "label_id_or_ref": "$youtube_label",
      "scene_name": "YouTube",
      "section_id": -1,
      "icon_id": 0,
      "flags": 1
    }
  ]
}

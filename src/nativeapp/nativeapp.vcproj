	>
	<Platforms>
		<Platform
			Name="OpenZDK (ARMV4I)"
		/>
	</Platforms>
	<ToolFiles>
		<ToolFile
			RelativePath=".\tegra-shaders.rules"
		/>
	</ToolFiles>
	<Configurations>
		<Configuration
			Name="Debug|OpenZDK (ARMV4I)"
			OutputDirectory="$(ProjectDir)bin\$(PlatformName)\$(ConfigurationName)"
			IntermediateDirectory="$(ProjectDir)obj\$(PlatformName)\$(ConfigurationName)"
			ConfigurationType="1"
			UseOfATL="0"
			CharacterSet="1"
			>
			<Tool
				Name="VCPreBuildEventTool"
			/>
			<Tool
				Name="VCCustomBuildTool"
			/>
			<Tool
				Name="Fragment Program"
			/>
			<Tool
				Name="Vertex Program"
			/>
